<Window x:Class="Test_KONTUR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обработчик данных" 
        Height="500" 
        Width="700"
        MinWidth="500" 
        MinHeight="400"
        WindowStartupLocation="CenterScreen">

    <TabControl>
        <TabItem Header="Модуль 1">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="DataFile" Margin="0,5"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" 
                             Text="{Binding Task1VM.InputFilePath, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,5,0"/>
                    <Button Grid.Column="1" 
                            Content="Открыть" 
                            Command="{Binding Task1VM.SelectInputCommand}" 
                            Width="60"/>
                </Grid>

                <TextBlock Grid.Row="2" Text="CsvFile" Margin="0,10,0,5"/>
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" 
                             Text="{Binding Task1VM.OutputFilePath, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,5,0"/>
                    <Button Grid.Column="1" 
                            Content="Открыть" 
                            Command="{Binding Task1VM.SelectOutputCommand}" 
                            Width="60"/>
                </Grid>

                <Button Grid.Row="4" 
                        Content="Запустить процесс" 
                        Command="{Binding Task1VM.ProcessCommand}"
                        IsEnabled="{Binding Task1VM.IsNotProcessing}"
                        Width="120" 
                        Height="30" 
                        Margin="0,15,0,0"
                        HorizontalAlignment="Left"/>

                <ProgressBar Grid.Row="5" 
                             Height="20" 
                             Value="{Binding Task1VM.Progress}" 
                             Margin="0,15,0,5"/>

                <TextBlock Grid.Row="6" 
                           Text="{Binding Task1VM.StatusMessage}" 
                           Margin="0,5"
                           TextWrapping="Wrap"/>
            </Grid>
        </TabItem>

        <TabItem Header="Модуль 2">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="DataFile" Margin="0,5"/>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" 
                             Text="{Binding Task2VM.InputFilePath, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,5,0"/>
                    <Button Grid.Column="1" 
                            Content="Открыть" 
                            Command="{Binding Task2VM.SelectInputCommand}" 
                            Width="60"/>
                </Grid>

                <TextBlock Grid.Row="2" Text="CsvFile" Margin="0,10,0,5"/>
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" 
                             Text="{Binding Task2VM.OutputFilePath, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="0,0,5,0"/>
                    <Button Grid.Column="1" 
                            Content="Открыть" 
                            Command="{Binding Task2VM.SelectOutputCommand}" 
                            Width="60"/>
                </Grid>

                <Button Grid.Row="4" 
                        Content="Запустить процесс" 
                        Command="{Binding Task2VM.ProcessCommand}"
                        IsEnabled="{Binding Task2VM.IsNotProcessing}"
                        Width="120" 
                        Height="30" 
                        Margin="0,15,0,0"
                        HorizontalAlignment="Left"/>

                <ProgressBar Grid.Row="5" 
                             Height="20" 
                             Value="{Binding Task2VM.Progress}" 
                             Margin="0,15,0,5"/>

                <TextBlock Grid.Row="6" 
                           Text="{Binding Task2VM.StatusMessage}" 
                           Margin="0,5"
                           TextWrapping="Wrap"/>
            </Grid>
        </TabItem>
    </TabControl>
</Window>